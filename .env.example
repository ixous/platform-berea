# ============================================================
# Centro Cristiano Berea Website - Environment Variables
# ============================================================
# Never commit real secrets to the repository.
# Copy this file to .env.local and fill in the values.
# ============================================================

# Application
APP_NAME="Centro Cristiano Berea"
APP_URL="http://localhost:3000"
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/berea?sslmode=require"

# Authentication (Auth.js)
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# Seed — Initial Admin User
# Required for db:seed script.
# Set SEED_ADMIN_EMAIL and SEED_ADMIN_PASSWORD before running seeds.
SEED_ADMIN_EMAIL="admin@centrocristianoberea.org"
SEED_ADMIN_PASSWORD="Change-Me-In-Prod-2026!"
SEED_ADMIN_NAME="Admin"

# Multimedia (Cloudflare R2)
MEDIA_STORAGE_PROVIDER="cloudflare-r2"
MEDIA_BUCKET="berea-media"
MEDIA_REGION="auto"
MEDIA_PUBLIC_URL="https://media.centrocristianoberea.org"

# Cloudflare R2 Credentials
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_ENDPOINT=""

# Video (Cloudflare Stream)
VIDEO_PROVIDER="cloudflare-stream"
VIDEO_API_KEY=""
VIDEO_WEBHOOK_SECRET=""

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Email (Resend — transactional)
RESEND_API_KEY=""
FROM_EMAIL="noreply@centrocristianoberea.org"
CONTACT_TO_EMAIL="admin@centrocristianoberea.org"

# Donations (Stripe - Future)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_KEY=""

# Email (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
MAIL_FROM=""

# Google Maps
GOOGLE_MAPS_API_KEY=""

# Analytics
GOOGLE_ANALYTICS_ID=""

# Security
ENCRYPTION_KEY=""
